@model Post

@{
    ViewData["Title"] = Model.Title;
}

<style>
    .content-wrapper{
        padding:20px;
        max-width:1000px;
        margin: 0 auto;
        font-family: sans-serif;
    }
    .feature-image {
        width:100%;
        height:500px;
        object-fit: cover;
        margin-bottom:20px;
    }
</style>

<div class=" text-end">
    <a class="btn btn-secondary my-3">Edit Post</a>
    <a class="btn btn-danger mx-3 my-3">Delete Post</a>
</div>

<div class=" content-wrapper">
    <h1>@Model.Title</h1>
    <p> <span class=" badge bg-primary">By:</span>@Model.Author | <span class="badge bg-primary">Published on</span>@Model.PublishedDate.ToString("MMMM dd, yyyy")</p>
    <p> <span class=" badge bg-secondary"> Category</span>@Model.Category.Name </p>
    <img src="@Model.FeatureImagePath" alt=" @Model.Title" class="feature-image"/>
    <hr />
    <div>
        @Html.Raw(@Model.Content)
    </div>
    <hr />
    @if (Model.Comments.Any())
    {
        <div>
            @foreach(var Comment in Model.Comments){
                <div class="card mb-3 shadow">
                    <div class=" card-body"> 
                        <h5 class=" card-title">@Comment.UserName</h5>
                        <p class="card-text text-muted" >@Comment.CommentDate.ToString("MMMM dd, yyyy")</p>
                        <p class="card-text">@Comment.Content</p>
                    </div>
                   
                </div>
            }
        </div>
    }
    else
    {
       <p class=" text-muted">No comments yet. Be the first to comment. </p>
    }
    <h4>Add a Comment</h4>
    <form id="CommentForm">
    <div class=" form-group">
        <label for="Username">Name</label>
        <input for ="Username"id=" UserName" name=" Username" required class=" form-control"/>
    </div>
    <div class=" form-group">
        <label for="Content">Content</label>
        <textarea for="Content" id=" Content" name="Content" rows="3" required class="form-control" /> </textarea>
    </div>
    <button type="submit" class=" btn btn-primary mt-2 p-2 rounded">Submit comment</button>
    </form>
</div>

@section Scripts{
    <script>
        $(document).ready(function(){
            $("#CommentForm").on('submit',function(event){
                event.preventDefault();
                var userName = $("#UserName").val();
                var content = $("#Content").val();
                var postId = @Model.Id;

                // console.log(username,content,postId;
                $.ajax({
                        url:'@Url.Action("AddComment", "Post")',
                        type:'POST',
                        contentType:'application/json',
                        data:JSON.stringify({
                            UserName: userName,
                            Content: content,
                            PostId:postId
                        }),
                        Success :function(response){
                            console.log("Success")
                        }
                })
            });
        });
    </script>
}

